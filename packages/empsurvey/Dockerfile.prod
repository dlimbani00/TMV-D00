FROM node:20-alpine AS build-survey

WORKDIR /app

COPY package*.json ./
COPY packages/arya-design-system/package.json packages/arya-design-system/
COPY packages/empsurvey packages/empsurvey/

RUN npm install

WORKDIR /app/packages/empsurvey

RUN npm run build

FROM nginx:1.25-alpine

COPY --from=build-survey /app/packages/empsurvey/dist /usr/share/nginx/html
COPY packages/empsurvey/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
